---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Billie — Terms of Service">
	<article class="mx-auto max-w-3xl space-y-10 px-2 pb-16 pt-4 sm:px-0">
		<header class="space-y-3">
			<p class="tag-pill">Terms of Service</p>
			<h1 class="text-3xl font-semibold text-black md:text-4xl">Terms for using Billie</h1>
			<p class="text-black/75">
